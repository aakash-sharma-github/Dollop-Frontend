{
  "expo": {
    "name": "Dollop",
    "slug": "dollop",
    "version": "1.2.2",
    "buildNumber": 11,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0805"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dollop.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0805"
      },
      "package": "com.dollop.app",
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-av",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0805",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Dollop to access your music library.",
          "savePhotosPermission": "Allow Dollop to save music to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "scheme": "dollop",
    "extra": {
      "eas": {
        "projectId": "fe89ca25-917f-437c-9f0c-9d73cb68738a"
      }
    },
    "owner": "aakash-expo"
  }
}
