{
  "extends": "expo/tsconfig.base",
  "name": "dollop",
  "compilerOptions": {
    "types": ["node"],
    "strict": true,
    "baseUrl": "./src",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@components/*": ["components/*"],
      "@screens/*": ["screens/*"],
      "@services/*": ["services/*"],
      "@hooks/*": ["hooks/*"],
      "@store/*": ["store/*"],
      "@theme/*": ["theme/*"],
      "@navigation/*": ["navigation/*"],
      "@constants/*": ["constants/*"],
      "@app-types/*": ["types/*"],
      "@utils/*": ["utils/*"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "App.tsx", "app.json"]
}
