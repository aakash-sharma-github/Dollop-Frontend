# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Create a "Web application" client (Supabase uses web client ID for signInWithIdToken)
# Add this to Authorised redirect URIs: https://auth.expo.io/@your-expo-username/dollop
# Also add it in: Supabase → Auth → Providers → Google → Client ID + Secret
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Dollop API
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1