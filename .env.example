# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth
# Get from: Google Cloud Console → APIs & Services → Credentials → Web client ID
# Add to Supabase: Auth → Providers → Google
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Jamendo (free CC music API — full streaming, no payment required)
# Register at: https://developer.jamendo.com to get your own client_id
# Without this, the app falls back to the demo key (rate limited)
EXPO_PUBLIC_JAMENDO_CLIENT_ID=your_jamendo_client_id

# Dollop API
# On a physical device use your machine's LAN IP, NOT localhost
# Find it with: ifconfig | grep "inet " (mac/linux) or ipconfig (windows)
EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:4000/api/v1